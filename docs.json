      "dark": "#090014"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@chattermate.chat"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.chattermate.chat"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/chattermate/chattermate.chat",
      "discord": "https://discord.gg/XNCMg8jV8U"
    }
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-57P2P2RW"
    }
