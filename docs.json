      {
        "anchor": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/organization",
              "features/ai-configuration",
              "features/ai-customization",
              "features/workflow-builder",
              "features/knowledge-base",
              "features/mcp-tools",
              "features/testing",
              "features/widget",
              "features/widget-apps",
              "features/authentication",
              "features/file-attachments",
              "features/human-agents",
              "features/roles",
              "features/chat-management",
              "features/jira-integration"
            ]
          },
          {
            "group": "Developer Tools",
            "pages": [
              "features/agents-quickstart",
              "features/cli",
              "features/mcp-server"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/docker"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/chattermate/chattermate.chat",
          "icon": "github"
        }
      ]
