{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ChatterMate",
  "colors": {
    "primary": "#f34611",
    "light": "#62CFE5",
    "dark": "#000000"
  },
  "favicon": "/images/favicon/favicon-32x32.png",
  "navigation": {
